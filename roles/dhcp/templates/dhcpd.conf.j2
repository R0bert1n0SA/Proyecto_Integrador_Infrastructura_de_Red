{% if tsig_secret is defined %}
key "dhcp-update-key" {
  algorithm hmac-sha256;
  secret "{{ tsig_secret }}";
}

zone {{ dhcp_domain_name }}. {
  primary {{ dhcp_dns_server_ip }};
  key "dhcp-update-key";
}

zone {{ dhcp_subnet.split('.')[:3] | reverse | join('.') }}.in-addr.arpa. {
  primary {{ dhcp_dns_server_ip }};
  key "dhcp-update-key";
}

ddns-update-style interim;
ddns-domainname "{{ dhcp_domain_name }}.";
ddns-rev-domainname "in-addr.arpa.";
{% else %}
ddns-update-style none;
{% endif %}

option domain-name "{{ dhcp_domain_name }}";
option domain-name-servers {{ dhcp_domain_name_servers }};

default-lease-time {{ dhcp_default_lease_time }};
max-lease-time {{ dhcp_max_lease_time }};

authoritative;

subnet {{ dhcp_subnet }} netmask {{ dhcp_netmask }} {
  range {{ dhcp_range_start }} {{ dhcp_range_end }};
  option routers {{ dhcp_routers }};
  option subnet-mask {{ dhcp_netmask }};
  option broadcast-address {{ dhcp_broadcast }};
}

{% for host in dhcp_reservations %}
host {{ host.name }} {
  hardware ethernet {{ host.mac }};
{% if host.ip is defined %}
  fixed-address {{ host.ip }};
{% endif %}
  option host-name "{{ host.hostname }}";
{% if tsig_secret is defined %}
  ddns-hostname "{{ host.hostname }}";
{% endif %}
}
{% endfor %}
